# Supabase
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Twilio (driver invite SMS — optional in dev; logs link when unset)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Google Maps / Places (address autocomplete — optional in dev)
GOOGLE_MAPS_API_KEY=
# Places backend: "new" (Places API New) or "legacy" (classic Places API). Use one only.
GOOGLE_PLACES_API=new
# Set to true in local dev to use built-in UK demo addresses and avoid Google quota entirely.
GOOGLE_PLACES_MOCK=false
